{
  "name": "sovereign-shield",
  "version": "1.0.0",
  "description": "Decentralized content-moderation framework for individual sovereign control",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:prod": "node src/index.js",
    "start:dev": "npm run ensure-models && nodemon src/index.js",
    "dev": "npm run start:dev",
    "electron": "electron .",
    "electron:dev": "npm run ensure-models && electron .",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "ensure-models": "node -e \"const fs=require('fs'); if(!fs.existsSync('./models')) fs.mkdirSync('./models'); console.log('models directory ensured');\"",
    "check-models": "node -e \"const fs=require('fs'); if(!fs.existsSync('./models/content_classifier.onnx')){ console.error('Model missing at ./models/content_classifier.onnx'); process.exit(1);} console.log('Model present at ./models/content_classifier.onnx');\"",
    "download-models": "node scripts/download_models.js",
    "add-local-model": "node scripts/copy_model_local.js"
  },
  "keywords": [
    "content-moderation",
    "privacy",
    "ai",
    "onnx",
    "proxy",
    "vpn"
  ],
  "author": "Sovereign Shield Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "onnxruntime-node": "^1.16.0",
    "prom-client": "^15.1.3",
    "sharp": "^0.32.6",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.1",
    "ws": "^8.14.2"
  },
  "optionalDependencies": {
    "http-mitm-proxy": "^0.8.2",
    "selfsigned": "^1.10.11"
  },
  "devDependencies": {
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "https-proxy-agent": "^7.0.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "supertest": "^7.2.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "build": {
    "appId": "io.sovereignshield.desktop",
    "productName": "Sovereign Shield",
    "files": [
      "dist/**",
      "src/**",
      "package.json",
      "models/**",
      "data/**"
    ],
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dist": "electron-builder",
  "bin": {
    "install-ca": "bin/install-ca.js"
  }
}
